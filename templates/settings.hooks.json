{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "__LEAN_HOOK__" }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "__LEAN_HOOK__" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "__LEAN_HOOK__" }
        ]
      }
    ]
  }
}
